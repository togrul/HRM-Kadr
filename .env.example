APP_NAME=Laravel
APP_ENV=testing
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
DEBUGBAR_ENABLED=false
DEBUGBAR_STORAGE_ENABLED=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

ACTIVITY_LOG_ENABLED=true
ACTIVITY_LOG_CONNECTION=sqlite
ACTIVITY_LOG_RETENTION_DAYS=730
ACTIVITY_LOG_RETENTION_SCHEDULE_ENABLED=false
ACTIVITY_LOG_RETENTION_DAILY_AT=02:30
ACTIVITY_LOG_TABLE_NAME=activity_log

# Production audit DB example:
# ACTIVITY_LOG_CONNECTION=audit
# AUDIT_DB_HOST=127.0.0.1
# AUDIT_DB_PORT=3306
# AUDIT_DB_DATABASE=hrm_audit
# AUDIT_DB_USERNAME=
# AUDIT_DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

ORDERS_ENGINE_STRICT_MODE=true
ORDERS_QUERY_BUDGET_ADD_FORM_SCHEMA=15
ORDERS_QUERY_BUDGET_EDIT_ORDER_LOAD=15
ORDERS_QUERY_BUDGET_PRINT_PAYLOAD_BUILD=20

ORDERS_TEMPLATE_REPORTS_ENABLED=false
ORDERS_TEMPLATE_REPORTS_DAILY_AT=09:00
ORDERS_TEMPLATE_REPORTS_WEEKLY_DAY=1
ORDERS_TEMPLATE_REPORTS_WEEKLY_AT=09:00
ORDERS_TEMPLATE_REPORT_CHANNELS=log
ORDERS_TEMPLATE_REPORT_LOG_FILE=logs/orders-template-metrics.log
ORDERS_TEMPLATE_REPORT_SLACK_WEBHOOK=
ORDERS_TEMPLATE_REPORT_TELEGRAM_BOT_TOKEN=
ORDERS_TEMPLATE_REPORT_TELEGRAM_CHAT_ID=
ORDERS_TEMPLATE_REPORT_METRICS_MAX_ERROR_RATE=1
ORDERS_TEMPLATE_REPORT_METRICS_MAX_P95=800
ORDERS_TEMPLATE_REPORT_METRICS_MAX_P99=1200
ORDERS_TEMPLATE_REPORT_METRICS_MIN_TOTAL=1

BLAZE_ENABLED=true
BLAZE_DEBUG=false

APP_TYPE=default
APP_CANDIDATE_MODE=auto

ATTENDANCE_INGEST_TOKEN=
ATTENDANCE_INGEST_DEFAULT_SOURCE=api
ATTENDANCE_INGEST_AUTO_PROCESS=false
ATTENDANCE_PROCESS_DEFAULT_WINDOW_HOURS=48
ATTENDANCE_PROCESS_SCHEDULE_ENABLED=false
ATTENDANCE_PROCESS_SCHEDULE_EVERY_MINUTES=10
ATTENDANCE_POLICY_OVERTIME=by_approval
ATTENDANCE_POLICY_ROUNDING=none
ATTENDANCE_POLICY_ROUNDING_STEP_MINUTES=5
ATTENDANCE_SNAPSHOT_SCHEDULE_ENABLED=false
ATTENDANCE_SNAPSHOT_SCHEDULE_DAY=1
ATTENDANCE_SNAPSHOT_SCHEDULE_AT=01:30
ATTENDANCE_SNAPSHOT_SCHEDULE_LOCK=false
ATTENDANCE_EXPORT_CSV_DELIMITER=;
ATTENDANCE_EXPORT_CSV_ENCLOSURE='"'
ATTENDANCE_EXPORT_CSV_LINE_ENDING="\n"
ATTENDANCE_EXPORT_CSV_USE_BOM=true
ATTENDANCE_EXPORT_CSV_OUTPUT_ENCODING=UTF-8
ATTENDANCE_REPORTS_ENABLED=false
ATTENDANCE_REPORT_DAILY_AT=08:30
ATTENDANCE_REPORT_WEEKLY_DAY=1
ATTENDANCE_REPORT_WEEKLY_AT=08:30
ATTENDANCE_REPORT_APPEND_OUTPUT=true
ATTENDANCE_REPORT_OUTPUT_FILE=logs/attendance-query-budget.log
ATTENDANCE_REPORT_MAX_OVER_BUDGET_PROBES=0
ATTENDANCE_REPORT_MAX_FAILED_PROBES=0

EMPLOYEE_LIFECYCLE_REMINDERS_SCHEDULE_ENABLED=false
EMPLOYEE_LIFECYCLE_REMINDERS_DAILY_AT=05:40
EMPLOYEE_LIFECYCLE_REMINDERS_DAYS_AHEAD=3
EMPLOYEE_LIFECYCLE_REMINDERS_COOLDOWN_HOURS=24
EMPLOYEE_LIFECYCLE_REMINDERS_MAX_PER_RUN=150
EMPLOYEE_LIFECYCLE_MOVEMENT_ORDER_IDS=
EMPLOYEE_LIFECYCLE_PROMOTION_ORDER_IDS=
EMPLOYEE_LIFECYCLE_TRANSFER_ORDER_IDS=
EMPLOYEE_LIFECYCLE_OFFBOARDING_ORDER_IDS=

COMPLIANCE_DOCUMENT_REMINDERS_ENABLED=false
COMPLIANCE_DOCUMENT_REMINDERS_DAILY_AT=05:55
COMPLIANCE_DOCUMENT_REMINDERS_DAYS_AHEAD=30
