{
    "name": "hrm/hrm",
    "type": "project",
    "description": "HRM — modular Laravel HR/HCM system for uniformed-service personnel management.",
    "keywords": [
        "laravel",
        "hr",
        "hcm",
        "modular-monolith"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "guzzlehttp/guzzle": "^7.2",
        "kwn/number-to-words": "^2.9",
        "laravel/framework": "^12.0",
        "laravel/pail": "^1.2",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "livewire/blaze": "^1.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1",
        "phpoffice/phpword": "^1.2",
        "spatie/laravel-activitylog": "^4.10",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.9.1",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^1.0",
        "laravel/pint": "^1.17",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Modules\\": "app/Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "ci:blaze-safe-lint": [
            "@php artisan views:blaze-safe-lint --strict"
        ],
        "ci:phpstan": [
            "@php vendor/bin/phpstan analyse --no-progress --memory-limit=1G"
        ],
        "ci:translations": [
            "@php artisan translations:lint",
            "@php artisan test tests/Unit/Architecture/TranslationCatalogLintTest.php tests/Unit/Architecture/ModuleTranslationNamespaceTest.php tests/Unit/Services/ServicesPermissionTranslationMapTest.php"
        ],
        "ci:ui-icon-smoke": [
            "@php artisan test tests/Unit/Architecture/CriticalActionIconsSmokeTest.php"
        ],
        "ci:orders-template-gate": [
            "@ci:blaze-safe-lint",
            "@ci:ui-icon-smoke",
            "@php artisan orders:templates:metrics --json --min-total=1",
            "@php artisan orders:templates:query-budget --json --allow-empty"
        ],
        "ci:attendance-gate": [
            "@ci:blaze-safe-lint",
            "@php artisan attendance:query-budget --json --allow-empty",
            "@php artisan test tests/Unit/Architecture/AttendanceLivewireReadBoundaryTest.php tests/Feature/Console/AttendanceQueryBudgetCommandTest.php"
        ],
        "ci:audit-gate": [
            "@php artisan audit:query-budget --json --allow-empty",
            "@php artisan audit:retention-status --json",
            "@php artisan test tests/Feature/Audit/AuditLogDashboardTest.php tests/Feature/Console/AuditQueryBudgetCommandTest.php"
        ],
        "ci:strategic-hr-gate": [
            "@php artisan employee-lifecycle:query-budget --json --allow-empty",
            "@php artisan compliance:document-query-budget --json --allow-empty",
            "@php artisan candidates:ats-query-budget --json --allow-empty",
            "@php artisan assets:manifest-check --json",
            "@php artisan test tests/Feature/Console/EmployeeLifecycleQueryBudgetCommandTest.php tests/Feature/Console/ComplianceDocumentQueryBudgetCommandTest.php tests/Feature/Console/CandidateAtsQueryBudgetCommandTest.php tests/Feature/Console/BuildAssetManifestCheckCommandTest.php tests/Feature/Compliance/ComplianceDocumentReminderCommandTest.php tests/Feature/Navigation/StrategicModuleMenuVisibilityTest.php tests/Unit/Modules/Candidates/CandidateApplicationStageServiceTest.php"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
